ANTHROPIC_API_KEY=sk-ant-...
BUSINESS_BOT_TOKEN=
PANEL_BOT_ANALYST_TOKEN=
PANEL_BOT_SKEPTIC_TOKEN=
PANEL_BOT_CREATIVE_TOKEN=
PANEL_BOT_PRAGMATIST_TOKEN=
PANEL_BOT_MODERATOR_TOKEN=
PANEL_CHAT_ID=
ADMIN_USER_ID=
CLAUDE_MODEL=claude-sonnet-4-6
LOG_LEVEL=INFO
PERSONAS_PATH=personas.yaml

# Optional Groq fallback (used when Claude is rate-limited or breaker opens).
# Leave empty to disable fallback (then persona.fallback templates are used instead).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter API — used for DeepSeek, Owl-Alpha and Gemini-Lite models.
OPENROUTER_API_KEY=
DEEPSEEK_MODEL=deepseek/deepseek-v4-flash:free
OWL_ALPHA_MODEL=openrouter/owl-alpha
GEMINI_LITE_MODEL=google/gemini-3.1-flash-lite

# Google Gemini API (optional — alternative provider for moderator or other personas).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Which provider to use for the moderator: "claude", "gemini", etc.
MODERATOR_PROVIDER=claude

# Google Calendar Integration settings
# Path to the Google Service Account JSON file (e.g. google_credentials.json)
# If left empty, Google Calendar integration will be disabled.
GOOGLE_SERVICE_ACCOUNT_FILE=
# ID of the Google Calendar to access (defaults to 'primary' which is the owner's main calendar)
GOOGLE_CALENDAR_ID=primary
# Timezone of the user to parse and format event start/end times correctly
USER_TIMEZONE=Europe/Moscow
